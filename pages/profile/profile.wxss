.profile-hero { margin-bottom: 24rpx; }
.summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.summary-card { text-align: center; }
.summary-number { margin-bottom: 8rpx; color: #0f766e; font-size: 48rpx; font-weight: 700; }
.menu-card { display: flex; align-items: center; }
.menu-card:active { background: #f0f8f6; }
.clear-card { margin-top: 34rpx; border: 1rpx solid #ffd8d2; }
.clear-note { margin: 10rpx 0 22rpx; }
