<view class="page">
  <view class="hero profile-hero">
    <view class="hero-title">{{appName}}</view>
    <view class="hero-subtitle">版本 {{version}} · {{releaseStatus}}</view>
  </view>

  <view class="summary-grid">
    <view class="card summary-card">
      <view class="summary-number">{{favoriteCount}}</view>
      <view class="muted small">收藏</view>
    </view>
    <view class="card summary-card">
      <view class="summary-number">{{targetCount}}</view>
      <view class="muted small">学习目标</view>
    </view>
    <view class="card summary-card">
      <view class="summary-number">{{schoolCount}}</view>
      <view class="muted small">学校</view>
    </view>
    <view class="card summary-card">
      <view class="summary-number">{{scoreCount}}</view>
      <view class="muted small">历史分数线</view>
    </view>
  </view>

  <view class="section-title">我的</view>
  <view class="card menu-card" bindtap="openFavorites"><view class="grow"><view class="card-title">我的收藏</view></view><view class="list-arrow">›</view></view>
  <view class="card menu-card" bindtap="openTargets"><view class="grow"><view class="card-title">学习目标</view></view><view class="list-arrow">›</view></view>

  <view class="section-title">设置</view>
  <view class="card menu-card" bindtap="openDataInfo"><view class="grow"><view class="card-title">数据说明</view></view><view class="list-arrow">›</view></view>
  <view class="card menu-card" bindtap="openPrivacy"><view class="grow"><view class="card-title">隐私说明</view></view><view class="list-arrow">›</view></view>

  <view class="card local-card">
    <view class="card-title">本地保存</view>
    <view class="muted small clear-note">收藏、学习目标记录和输入草稿只保存在当前设备。</view>
  </view>

  <view class="card clear-card">
    <view class="card-title danger-text">清除本地数据</view>
    <view class="muted small clear-note">清除收藏、学习目标记录和输入草稿。</view>
    <button class="button danger" bindtap="clearLocalData">清除本地数据</button>
  </view>
</view>
