<view class="page">
  <view class="hero compact-hero">
    <view class="hero-title">学习目标记录</view>
    <view class="hero-subtitle">记录当前测评分数、阶段目标和复盘备注</view>
  </view>

  <view class="card">
    <view class="section-heading">设置阶段目标</view>
    <text class="field-label">阶段测评分数</text>
    <input class="input" type="number" maxlength="{{scoreMaxLength}}" value="{{currentScore}}" placeholder="请输入 {{scoreMin}} 至 {{scoreMax}} 的整数" bindinput="onCurrentInput" />
    <text class="field-label">阶段目标分数</text>
    <input class="input" type="number" maxlength="{{scoreMaxLength}}" value="{{targetScore}}" placeholder="请输入 {{scoreMin}} 至 {{scoreMax}} 的整数" bindinput="onTargetInput" />
    <text class="field-label">备注</text>
    <textarea class="input textarea" maxlength="200" value="{{note}}" placeholder="请勿填写姓名、手机号、身份证、准考证号等个人敏感信息。" bindinput="onNoteInput"></textarea>

    <view class="summary-box">
      <view class="summary-title">{{gapText}}</view>
      <view class="muted small">{{reminder}}</view>
    </view>

    <view class="button-row">
      <button class="button" bindtap="saveRecord">保存学习目标</button>
      <button class="button ghost" bindtap="clearInputs">清空输入</button>
    </view>
  </view>

  <view class="row between section-row">
    <view class="section-title records-title">学习目标记录（{{records.length}}）</view>
    <button wx:if="{{records.length > 0}}" class="button danger small-button" bindtap="clearAllRecords">清空全部</button>
  </view>

  <view wx:if="{{records.length === 0}}" class="card empty">
    <view class="card-title">暂无学习目标记录</view>
    <view class="muted small">填写阶段测评分数与阶段目标分数后即可保存在本机。</view>
  </view>

  <view class="card record-card" wx:for="{{records}}" wx:key="id">
    <view class="row between">
      <view class="card-title">测评 {{item.currentScore}} / 目标 {{item.targetScore}}</view>
      <button class="button danger small-button" data-id="{{item.id}}" bindtap="deleteRecord">删除</button>
    </view>
    <view class="gap-line">{{item.gapText}}</view>
    <view class="muted small">{{item.reminder}}</view>
    <view wx:if="{{item.note}}" class="record-note">备注：{{item.note}}</view>
    <view class="muted small record-time">{{item.displayTime}}</view>
  </view>
</view>
