.section-heading { margin-bottom: 14rpx; font-size: 30rpx; font-weight: 700; }
.summary-box { margin-top: 24rpx; padding: 24rpx; background: #edf8f5; border-radius: 18rpx; }
.summary-title { margin-bottom: 8rpx; color: #0f766e; font-weight: 700; }
.section-row { margin-top: 4rpx; }
.records-title { margin: 24rpx 0 18rpx; }
.gap-line { margin: 18rpx 0 8rpx; color: #0f766e; font-weight: 600; }
.record-note { margin-top: 16rpx; padding: 18rpx; background: #f5f7f6; border-radius: 14rpx; line-height: 1.6; }
.record-time { margin-top: 14rpx; }
