.compact-hero { margin-bottom: 24rpx; }
.filter-grid { display: grid; gap: 14rpx; margin-top: 18rpx; }
.filter-control { padding: 20rpx 22rpx; background: #ffffff; border: 2rpx solid #dbe5e2; border-radius: 16rpx; }
.result-line { margin: 22rpx 0; }
.favorite-button { flex-shrink: 0; margin-left: 14rpx; }
.tag-line { margin-top: 18rpx; }
.school-card:active { background: #f0f8f6; }
.demo-card { border-color: #f4d58d; background: #fffdf5; }
.demo-note {
  margin-top: 14rpx;
  color: #92400e;
  font-size: 24rpx;
  line-height: 1.5;
}
.empty-button { margin: 24rpx auto 0; width: 260rpx; }
