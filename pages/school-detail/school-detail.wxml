<view class="page">
  <view wx:if="{{!school}}" class="card empty">
    <view class="card-title">未找到学校数据，请返回学校库重新选择</view>
    <button class="button empty-button" bindtap="openSchools">返回学校库</button>
  </view>

  <block wx:if="{{school}}">
    <view class="hero detail-hero">
      <view class="hero-title">{{school.name}}</view>
      <view class="hero-subtitle">{{school.district}} · {{school.schoolType}}</view>
      <view class="detail-badges">
        <text class="badge">{{school.sourceTypeLabel}}</text>
        <text class="badge">{{school.admissionScoreBadge}}</text>
      </view>
    </view>

    <view class="card detail-card">
      <view class="section-heading">基础信息</view>
      <view class="info-row"><text class="info-label">区域</text><text class="info-value">{{school.district}}</text></view>
      <view class="info-row"><text class="info-label">类型</text><text class="info-value">{{school.schoolType}}</text></view>
      <view wx:if="{{school.ownership}}" class="info-row"><text class="info-label">办学性质</text><text class="info-value">{{school.ownership}}</text></view>
      <view wx:if="{{school.campus}}" class="info-row"><text class="info-label">校区</text><text class="info-value">{{school.campus}}</text></view>
      <view wx:if="{{school.address}}" class="info-row"><text class="info-label">地址</text><text class="info-value">{{school.address}}</text></view>
      <view class="tag-line">
        <text class="badge" wx:for="{{school.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="muted small detail-notice">{{detailNotice}}</view>
    </view>

    <view wx:if="{{school.intro}}" class="card">
      <view class="section-heading">学校简介</view>
      <view class="notice">{{school.intro}}</view>
    </view>

    <view wx:if="{{school.features && school.features.length}}" class="card">
      <view class="section-heading">办学特色</view>
      <view class="notice list-item" wx:for="{{school.features}}" wx:key="*this">{{item}}</view>
    </view>

    <view wx:if="{{school.programs && school.programs.length}}" class="card">
      <view class="section-heading">课程/项目</view>
      <view class="notice list-item" wx:for="{{school.programs}}" wx:key="*this">{{item}}</view>
    </view>

    <view class="card score-card">
      <view class="section-heading">历史录取分数线</view>
      <view wx:if="{{scoreGroups.length === 0}}" class="notice">{{emptyScoreText}}</view>
      <view wx:for="{{scoreGroups}}" wx:key="year" class="score-year">
        <view class="score-year-title">{{item.year}} 年</view>
        <view wx:for="{{item.items}}" wx:for-item="score" wx:key="id" class="score-item">
          <view class="score-main">{{score.region}} · {{score.batch}}</view>
          <view class="muted small">{{score.admissionType}} · {{score.scoreType}}：{{score.minScore}}</view>
          <view wx:if="{{score.sameScoreRule}}" class="muted small">{{score.sameScoreRule}}</view>
          <view class="muted small">{{score.sourceTitle}}</view>
          <view class="muted small">核对日期：{{score.sourceCheckedAt}}</view>
          <button class="button secondary small-button copy-source" data-url="{{score.sourceUrl}}" catchtap="copyScoreSource">复制分数线来源链接</button>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-heading">数据来源</view>
      <view class="info-row"><text class="info-label">来源标题</text><text class="info-value">{{school.sourceTitle}}</text></view>
      <view class="info-row"><text class="info-label">来源类型</text><text class="info-value">{{school.sourceTypeLabel}}</text></view>
      <view class="info-row"><text class="info-label">核对日期</text><text class="info-value">{{school.sourceCheckedAt}}</text></view>
      <view class="notice source-note">{{school.sourceNote}}</view>
      <button class="button secondary copy-source" bindtap="copySourceLink">复制来源链接</button>
    </view>

    <view class="card safety-card">
      <view class="section-heading">安全说明</view>
      <view class="notice">{{scoreSafetyNotice}}</view>
    </view>

    <view class="card">
      <view class="section-heading">操作</view>
      <view class="button-row">
        <button class="button" bindtap="toggleFavorite">{{isFavorite ? '取消收藏' : '收藏学校'}}</button>
        <button class="button secondary" bindtap="copySchoolName">复制学校名称</button>
        <button wx:if="{{school.address}}" class="button secondary" bindtap="copyAddress">复制地址</button>
        <button wx:if="{{school.officialWebsite}}" class="button secondary" bindtap="copyOfficialWebsite">复制官网链接</button>
      </view>
    </view>
  </block>
</view>
