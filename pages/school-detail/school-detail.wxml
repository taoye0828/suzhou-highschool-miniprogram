<view class="page">
  <view wx:if="{{!school}}" class="card empty">
    <view class="card-title">未找到学校数据</view>
    <view class="muted small">请返回学校库重新选择。</view>
  </view>

  <block wx:if="{{school}}">
    <view class="hero detail-hero">
      <view class="hero-title">{{school.name}}</view>
      <view class="hero-subtitle">{{school.district}} · {{school.schoolType}}</view>
      <view class="detail-badges">
        <text class="badge {{school.dataKind === 'demo' ? 'demo' : ''}}">{{school.dataStatus}}</text>
        <text class="badge">{{school.sourceTypeLabel}}</text>
      </view>
    </view>

    <view class="card detail-card">
      <view class="section-heading">基础信息</view>
      <view class="info-row"><text class="info-label">区域</text><text class="info-value">{{school.district}}</text></view>
      <view class="info-row"><text class="info-label">类型</text><text class="info-value">{{school.schoolType}}</text></view>
      <view class="info-row"><text class="info-label">办学性质</text><text class="info-value">{{school.ownership}}</text></view>
      <view class="info-row"><text class="info-label">住宿状态</text><text class="info-value">{{school.boardingType}}</text></view>
      <view class="info-row"><text class="info-label">数据状态</text><text class="info-value">{{school.dataStatus}}</text></view>
      <view class="divider"></view>
      <view class="notice">{{school.intro}}</view>
      <view class="tag-line">
        <text class="badge" wx:for="{{school.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="muted small detail-notice">{{detailNotice}}</view>
    </view>

    <view class="card">
      <view class="section-heading">来源信息</view>
      <view class="info-row"><text class="info-label">来源标题</text><text class="info-value">{{school.sourceTitle}}</text></view>
      <view class="info-row"><text class="info-label">来源链接</text><text class="info-value link-text">{{school.sourceUrl || '示例数据无来源链接'}}</text></view>
      <view class="info-row"><text class="info-label">查询日期</text><text class="info-value">{{school.sourceCheckedAt}}</text></view>
      <view class="notice source-note">{{school.sourceNote}}</view>
    </view>

    <view class="card">
      <view class="section-heading">信息完整度</view>
      <view class="info-row" wx:for="{{completenessItems}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value">{{item.value}}</text>
      </view>
    </view>

    <view class="card map-card">
      <view class="section-heading">地图说明</view>
      <view class="notice">当前版本不请求定位、不内置地图 SDK。你可以复制“学校名称 + 苏州”后到高德地图、腾讯地图或百度地图中搜索。</view>
    </view>

    <view class="card">
      <view class="section-heading">操作</view>
      <view class="button-row">
        <button class="button" bindtap="toggleFavorite">{{isFavorite ? '取消收藏' : '收藏学校'}}</button>
        <button class="button secondary" bindtap="copySchoolName">复制学校名称</button>
        <button class="button secondary" bindtap="copyMapKeyword">复制地图搜索词</button>
        <button class="button secondary" bindtap="copySourceLink">复制来源链接</button>
        <button wx:if="{{school.officialWebsite}}" class="button secondary" bindtap="copyOfficialWebsite">复制官网链接</button>
      </view>
    </view>
  </block>
</view>
