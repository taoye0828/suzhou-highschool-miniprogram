.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.hero {
  padding: 40rpx 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #155e75);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}

.hero-title { font-size: 42rpx; font-weight: 700; line-height: 1.3; }
.hero-subtitle { margin-top: 16rpx; color: rgba(255, 255, 255, 0.9); line-height: 1.7; }
.section-title { margin: 36rpx 0 18rpx; font-size: 32rpx; font-weight: 700; }

.card {
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e5ebe9;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 50, 48, 0.05);
}

.card-title { font-size: 31rpx; font-weight: 650; line-height: 1.45; }
.muted { color: #64748b; line-height: 1.65; }
.small { font-size: 24rpx; }
.notice { color: #475569; line-height: 1.75; }
.danger-text { color: #b42318; }

.badge {
  display: inline-flex;
  align-items: center;
  margin: 0 12rpx 12rpx 0;
  padding: 8rpx 16rpx;
  color: #0f766e;
  background: #e7f6f3;
  border-radius: 999rpx;
  font-size: 23rpx;
}

.badge.demo { color: #805600; background: #fff5d6; }
.row { display: flex; align-items: center; gap: 16rpx; }
.between { justify-content: space-between; }
.wrap { flex-wrap: wrap; }
.grow { flex: 1; min-width: 0; }
.divider { height: 1rpx; margin: 24rpx 0; background: #e8eeec; }

.input {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  background: #ffffff;
  border: 2rpx solid #dbe5e2;
  border-radius: 18rpx;
}

.textarea { height: 176rpx; }
.field-label { display: block; margin: 22rpx 0 10rpx; font-weight: 600; }

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 76rpx;
  margin: 0;
  padding: 14rpx 24rpx;
  color: #ffffff;
  background: #0f766e;
  border-radius: 16rpx;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.3;
}

.button.secondary { color: #0f766e; background: #e7f6f3; }
.button.ghost { color: #475569; background: #eef2f1; }
.button.danger { color: #b42318; background: #fff0ee; }
.button.small-button { min-height: 62rpx; padding: 10rpx 20rpx; font-size: 24rpx; }
.button-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 22rpx; }
.button-row .button { flex: 1; min-width: 220rpx; }

.empty { padding: 64rpx 30rpx; text-align: center; color: #64748b; }
.list-arrow { color: #94a3b8; font-size: 34rpx; }
.info-row { display: flex; padding: 13rpx 0; line-height: 1.55; }
.info-label { width: 176rpx; flex-shrink: 0; color: #64748b; }
.info-value { flex: 1; }
